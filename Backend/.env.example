# RentalPro Backend Environment Variables
# Copy this file to .env and update with your actual values

# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/rentalpro_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# CORS Configuration (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Configuration
JWT_SECRET=your-secret-key-at-least-32-characters-long-for-security
JWT_EXPIRATION=86400000

# Cloudinary Configuration (for file uploads)
# Sign up at https://cloudinary.com (free, no credit card)
# Set CLOUDINARY_ENABLED=true after getting credentials
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Spring Profile (local, dev, prod)
SPRING_PROFILES_ACTIVE=local
